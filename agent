      place-items: center;
      text-align: center;
      font-weight: 800;
      font-size: 1.55rem;
      line-height: 1.05;
    }

    .score small {
      display: block;
      font-size: .72rem;
      letter-spacing: .04em;
      margin-top: 4px;
      opacity: .9;
    }

    .stat-line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,.18);
      font-size: .92rem;
