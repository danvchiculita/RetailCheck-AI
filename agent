    }

    .hero-side {
      display: grid;
      gap: 16px;
    }

    .insight-card {
      padding: 22px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fbfe 100%);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
