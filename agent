      box-shadow: 0 10px 18px rgba(0,0,0,.12);
    }

    .prod.red { background: linear-gradient(180deg, #dd5960, #b62d39); }
    .prod.blue { background: linear-gradient(180deg, #4a79b7, #1f4f88); }
    .prod.gray { background: linear-gradient(180deg, #acb6c2, #7d8b98); }
    .prod.gold { background: linear-gradient(180deg, #e3bf66, #c3922c); }

    .flag {
