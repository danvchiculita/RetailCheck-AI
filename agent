      color: var(--brand);
      border: 1px solid rgba(15, 47, 87, 0.1);
      font-size: .84rem;
      font-weight: 700;
      letter-spacing: .02em;
      margin-bottom: 18px;
    }

    h1, h2, h3, h4, p { margin-top: 0; }

    h1 {
      font-size: clamp(2rem, 4vw, 3.3rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
