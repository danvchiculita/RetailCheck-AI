<!DOCTYPE html>
<html lang="ro">
<head>
 <head>
  <meta charset="UTF-8">
  <title>Retail Check AI — LIVE</title>

  <style>
    body { font-family: Arial; background:#f4f7fb; }
    .container {
      max-width: 800px;
      margin: 60px auto;
      background: #fff;
      padding: 30px;
      border-radius: 12px;
    }
    button {
      background: #0f2f57;
      color: #fff;
      border: none;
      padding: 12px 20px;
      border-radius: 8px;
      cursor: pointer;
    }
    #result {
      margin-top: 20px;
      white-space: pre-wrap;
    }
    input, select {
      padding: 8px;
      margin-right: 8px;
    }
  
    :root {
      --bg: #f5f7fa;
      --surface: #ffffff;
      --surface-soft: #f8fafc;
      --text: #16202a;
      --muted: #5f6b76;
      --line: #d9e1e8;
      --brand: #0f2f57;
      --brand-2: #1f4f88;
      --danger: #c63d3d;
      --warning: #d99a1f;
      --success: #1f7a4f;
      --shadow: 0 18px 50px rgba(15, 47, 87, 0.08);
      --radius-xl: 24px;
      --radius-lg: 18px;
      --radius-md: 12px;
      --max: 1380px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f4f7fb 0%, #eef3f8 100%);
      color: var(--text);
    }

    .container {
      width: min(var(--max), calc(100% - 40px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(10px);
      background: rgba(245, 247, 250, 0.88);
      border-bottom: 1px solid rgba(217, 225, 232, 0.9);
    }

    .topbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 16px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand-badge {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      color: #fff;
      display: grid;
      place-items: center;
      font-weight: 700;
      letter-spacing: .04em;
      box-shadow: var(--shadow);
    }

    .brand-title {
      font-size: 1rem;
      font-weight: 700;
      margin: 0;
    }

    .brand-subtitle {
      margin: 2px 0 0;
      color: var(--muted);
      font-size: .9rem;
    }

    .nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav a,
    .btn,
    .ghost-btn {
      text-decoration: none;
      border-radius: 999px;
      padding: 11px 18px;
      font-size: .92rem;
      font-weight: 600;
      transition: .2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
    }

    .nav a,
    .ghost-btn {
      color: var(--brand);
      background: rgba(15, 47, 87, 0.05);
      border: 1px solid rgba(15, 47, 87, 0.1);
    }

    .nav a:hover,
    .ghost-btn:hover {
      background: rgba(15, 47, 87, 0.1);
    }

    .btn {
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      color: #fff;
      border: none;
      box-shadow: 0 14px 30px rgba(15, 47, 87, 0.18);
    }

    .btn:hover { transform: translateY(-1px); }

    .hero {
      padding: 54px 0 26px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 24px;
      align-items: stretch;
    }

    .hero-card,
    .panel,
    .card,
    .demo-block,
    .tier {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
    }

    .hero-card {
      padding: 34px;
      position: relative;
      overflow: hidden;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -60px -60px auto;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(31,79,136,.14) 0%, rgba(31,79,136,0) 72%);
