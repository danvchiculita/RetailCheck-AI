    }

    .card-grid {
      display: grid;
      gap: 12px;
    }

    .score-card {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 14px;
      align-items: center;
      padding: 18px;
      background: linear-gradient(135deg, #0f2f57 0%, #1f4f88 100%);
