      .mini-kpis {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .container {
        width: min(var(--max), calc(100% - 22px));
      }

      .topbar-inner,
      .section-head {
        align-items: start;
        flex-direction: column;
      }

      .hero-card,
      .panel,
      .card,
      .demo-block,
      .tier {
        padding: 18px;
      }

      .score-card {
        grid-template-columns: 1fr;
      }

      .score {
        width: 88px;
        height: 88px;
      }

      .image-stage {
        min-height: 420px;
      }
    } 
