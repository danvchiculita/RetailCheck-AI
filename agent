    .footer-note {
      margin: 28px 0 46px;
      padding: 18px 20px;
      border-radius: 18px;
      background: rgba(15,47,87,.05);
      border: 1px solid rgba(15,47,87,.08);
      color: var(--muted);
      line-height: 1.7;
    }

    @media (max-width: 1100px) {
      .hero-grid,
      .wireframe-grid,
      .demo-main,
      .before-after,
      .tiers,
      .dual-grid {
